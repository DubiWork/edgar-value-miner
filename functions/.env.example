# Firebase Functions environment configuration
# Copy this file to functions/.env and fill in your values.
# NEVER commit functions/.env — it is in .gitignore.

# Firebase project ID (used by Admin SDK when running outside emulator)
FIREBASE_PROJECT_ID=your-project-id

# Service account key path (local dev only — use Workload Identity in CI/CD)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Emulator flag — set to "true" when running against local emulators
FUNCTIONS_EMULATOR=true

# API keys / external service credentials go here
# OPENAI_API_KEY=sk-...
